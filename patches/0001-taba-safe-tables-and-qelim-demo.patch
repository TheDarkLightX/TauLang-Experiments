diff --git a/src/boolean_algebras/finite_table_ba.h b/src/boolean_algebras/finite_table_ba.h
new file mode 100644
index 00000000..cb5047f8
--- /dev/null
+++ b/src/boolean_algebras/finite_table_ba.h
@@ -0,0 +1,185 @@
+// To view the license please visit https://github.com/IDNI/tau-lang/blob/main/LICENSE.md
+
+#ifndef __IDNI__TAU__BOOLEAN_ALGEBRAS__FINITE_TABLE_BA_H__
+#define __IDNI__TAU__BOOLEAN_ALGEBRAS__FINITE_TABLE_BA_H__
+
+#include <algorithm>
+#include <cctype>
+#include <cstdint>
+#include <cstdlib>
+#include <optional>
+#include <ostream>
+#include <string>
+
+#include "defs.h"
+#include "splitter_types.h"
+#include "tau_tree.h"
+
+namespace idni::tau_lang {
+
+struct ft4_ba {
+	static constexpr uint8_t mask_all = 0x0f;
+
+	uint8_t mask = 0;
+
+	ft4_ba() = default;
+	explicit ft4_ba(uint8_t m) : mask(m & mask_all) {}
+
+	static ft4_ba zero() { return ft4_ba(0); }
+	static ft4_ba one() { return ft4_ba(mask_all); }
+
+	ft4_ba operator&(const ft4_ba& x) const {
+		return ft4_ba(mask & x.mask);
+	}
+
+	ft4_ba operator|(const ft4_ba& x) const {
+		return ft4_ba(mask | x.mask);
+	}
+
+	ft4_ba operator^(const ft4_ba& x) const {
+		return ft4_ba(mask ^ x.mask);
+	}
+
+	ft4_ba operator+(const ft4_ba& x) const {
+		return *this ^ x;
+	}
+
+	ft4_ba operator~() const {
+		return ft4_ba(static_cast<uint8_t>(~mask));
+	}
+
+	auto operator<=>(const ft4_ba& x) const = default;
+
+	bool is_zero() const { return mask == 0; }
+	bool is_one() const { return mask == mask_all; }
+};
+
+inline bool tau_env_flag_enabled(const char* name) {
+	const char* flag = std::getenv(name);
+	if (!flag) return false;
+	std::string value(flag);
+	std::ranges::transform(value, value.begin(),
+		[](unsigned char c) { return static_cast<char>(std::tolower(c)); });
+	return value != "0" && value != "false" && value != "no";
+}
+
+inline bool safe_table_ba_enabled() {
+	return tau_env_flag_enabled("TAU_ENABLE_SAFE_TABLES");
+}
+
+inline bool finite_table_ba_enabled() {
+	if (safe_table_ba_enabled()) return true;
+	return tau_env_flag_enabled("TAU_ENABLE_FINITE_TABLES");
+}
+
+template<NodeType node>
+tref ft4_type() {
+	using tau = tree<node>;
+	tref type = tau::get(tau::type, "ft4");
+	return tau::get(tau::typed, type);
+}
+
+template<NodeType node>
+bool is_ft4_type(tref t) {
+	using tau = tree<node>;
+	return tau::get(t)[0].get_string() == "ft4";
+}
+
+inline ft4_ba normalize(const ft4_ba& f) { return ft4_ba(f.mask); }
+
+inline bool is_syntactic_one(const ft4_ba& f) { return f.is_one(); }
+
+inline bool is_syntactic_zero(const ft4_ba& f) { return f.is_zero(); }
+
+inline bool is_closed(const ft4_ba&) { return true; }
+
+inline uint8_t ft4_least_atom(uint8_t mask) {
+	return static_cast<uint8_t>(mask & static_cast<uint8_t>(-mask));
+}
+
+inline ft4_ba splitter(const ft4_ba& f, splitter_type&) {
+	return ft4_ba(f.mask == 0 ? 0 : ft4_least_atom(f.mask));
+}
+
+inline bool operator==(const ft4_ba& lhs, const bool& rhs) {
+	return rhs ? lhs.is_one() : lhs.is_zero();
+}
+
+inline bool operator==(const bool& lhs, const ft4_ba& rhs) {
+	return rhs == lhs;
+}
+
+inline bool operator!=(const ft4_ba& lhs, const bool& rhs) {
+	return !(lhs == rhs);
+}
+
+inline bool operator!=(const bool& lhs, const ft4_ba& rhs) {
+	return !(rhs == lhs);
+}
+
+inline std::ostream& operator<<(std::ostream& os, const ft4_ba& f) {
+	return os << static_cast<unsigned>(f.mask);
+}
+
+inline tref base_ba_symbol_simplification(tref symbol, const ft4_ba&) {
+	return symbol;
+}
+
+inline tref base_ba_term_simplification(tref term, const ft4_ba&) {
+	return term;
+}
+
+inline std::optional<uint8_t> parse_ft4_mask(std::string src) {
+	src.erase(std::remove_if(src.begin(), src.end(),
+		[](unsigned char c) { return std::isspace(c) || c == '{' || c == '}'; }),
+		src.end());
+	if (src.empty()) return {};
+
+	int base = 10;
+	if (src.size() > 2 && src[0] == '#' &&
+		(src[1] == 'x' || src[1] == 'X')) {
+		src = src.substr(2);
+		base = 16;
+	} else if (src.size() > 2 && src[0] == '0' &&
+		(src[1] == 'x' || src[1] == 'X')) {
+		src = src.substr(2);
+		base = 16;
+	}
+
+	size_t idx = 0;
+	try {
+		unsigned long value = std::stoul(src, &idx, base);
+		if (idx != src.size() || value > ft4_ba::mask_all) return {};
+		return static_cast<uint8_t>(value);
+	} catch (...) {
+		return {};
+	}
+}
+
+template<typename... BAs>
+requires BAsPack<BAs...>
+std::optional<typename node<BAs...>::constant_with_type> parse_ft4(
+	const std::string& src)
+{
+	using node_t = node<BAs...>;
+	if (!finite_table_ba_enabled()) {
+		LOG_ERROR << "ft4 constants require TAU_ENABLE_FINITE_TABLES=1";
+		return {};
+	}
+	auto mask = parse_ft4_mask(src);
+	if (!mask) return {};
+	return typename node_t::constant_with_type{
+		std::variant<BAs...>{ ft4_ba(*mask) },
+		ft4_type<node_t>() };
+}
+
+} // namespace idni::tau_lang
+
+template<>
+struct std::hash<idni::tau_lang::ft4_ba> {
+	size_t operator()(const idni::tau_lang::ft4_ba& f) const noexcept {
+		return static_cast<size_t>(f.mask);
+	}
+};
+
+#endif // __IDNI__TAU__BOOLEAN_ALGEBRAS__FINITE_TABLE_BA_H__
