diff --git a/parser/tau.tgf b/parser/tau.tgf
index eaaec434..29669e85 100644
--- a/parser/tau.tgf
+++ b/parser/tau.tgf
@@ -67,6 +67,7 @@ wff                    => ('(' _ wff _ ')')                  :wff_parenthesis
 bf                     => ('(' _ bf _ ')')                   :bf_parenthesis
                         |                                     ba_constant
                         |                                     variable
+                        |                                     safe_table_expr
                         | ("fall"     __ q_vars  __ bf)      :bf_fall
                         | ("fex"      __ q_vars  __ bf)      :bf_fex
                         | ref                                :bf_ref
@@ -101,6 +102,23 @@ bf                     => ('(' _ bf _ ')')                   :bf_parenthesis
                                 :bf_and_nosep_2nd_oprnd)     :bf_and_nosep
                         |                                     capture.
 
+# Feature-gated safe table terms.
+#
+# Semantics:
+#   table { when G1 => V1; when G2 => V2; else => D }
+# lowers to:
+#   (G1 & V1) | (G1' & ((G2 & V2) | (G2' & D)))
+#
+# This is a safe finite/infinite table surface because guards are ordinary Tau
+# boolean-algebra terms and the construct is only guarded choice. Recurrence,
+# same-stratum negation, and unrestricted TABA table semantics are deliberately
+# not introduced by this grammar production.
+safe_table_expr[safe_tables]
+                       => "table" _ '{' _ safe_table_rows
+                          _ "else" _ "=>" _ bf _ '}'.
+safe_table_rows        => safe_table_row (_ ';' _ safe_table_row)* [_ ';'].
+safe_table_row         => "when" __ bf _ "=>" _ bf.
+
 # constant time constraints
 constraint =>
           ("[" ctnvar _ "!=" _ num "]" | "[" num _ "!=" _ ctnvar "]"):ctn_neq
