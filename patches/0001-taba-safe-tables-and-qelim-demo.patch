@@ -0,0 +1,88 @@
+// To view the license please visit https://github.com/IDNI/tau-lang/blob/main/LICENSE.md
+
+#ifndef __IDNI__TAU__FINITE_TABLE_BUILTINS_H__
+#define __IDNI__TAU__FINITE_TABLE_BUILTINS_H__
+
+#include <cstdlib>
+#include <string>
+#include <vector>
+
+#include "boolean_algebras/finite_table_ba.h"
+#include "definitions.h"
+
+namespace idni::tau_lang::finite_table_builtins {
+
+inline bool enabled() {
+	return finite_table_ba_enabled() || safe_table_ba_enabled();
+}
+
+inline bool safe_enabled() {
+	return safe_table_ba_enabled();
+}
+
+template <NodeType node>
+bool ensure_loaded() {
+	static bool attempted = false;
+	static bool loaded = false;
+	if (attempted) return loaded;
+	attempted = true;
+
+	using tau = tree<node>;
+	auto& defs = definitions<node>::instance();
+	auto& ctx = *defs.get_io_context();
+
+	std::vector<std::string> prelude{
+		"ft_join4(a,b) : bv[8] := (a | b) & { #x0F }:bv[8]",
+		"ft_common4(a,b) : bv[8] := (a & b) & { #x0F }:bv[8]",
+		"ft_select4(a,g) : bv[8] := (a & g) & { #x0F }:bv[8]",
+		"ft_set4(a,g,v) : bv[8] := ((a & (g ^ { #xFF }:bv[8])) | (v & g)) & { #x0F }:bv[8]",
+		"ft_project4to2(a) : bv[8] := (((a & { #x01 }:bv[8]) | ((a >> { #x01 }:bv[8]) & { #x01 }:bv[8])) | ((((a >> { #x02 }:bv[8]) & { #x01 }:bv[8]) | ((a >> { #x03 }:bv[8]) & { #x01 }:bv[8])) << { #x01 }:bv[8]))"
+	};
+
+	if (safe_enabled()) {
+		prelude.insert(prelude.end(), {
+			"st_select4(x,g) : bv[8] := ft_select4(x,g)",
+			"st_choice4(g,u,v) : bv[8] := (((u & g) | (v & (g ^ { #xFF }:bv[8]))) & { #x0F }:bv[8])",
+			"st_revise4(x,g,a) : bv[8] := st_choice4(g,a,x)",
+			"st_pointwise_revise4(x,g,a) : bv[8] := st_revise4(x,g,a)",
+			"st_update4(x,b,g,a) : bv[8] := ft_join4(b, st_revise4(x,g,a))",
+			"st_select_tau(x,g) : tau := x & g",
+			"st_choice_tau(g,u,v) : tau := (u & g) | (v & g')",
+			"st_revise_tau(x,g,a) : tau := (a & g) | (x & g')",
+			"st_pointwise_revise_tau(x,g,a) : tau := st_revise_tau(x,g,a)",
+			"st_update_tau(x,b,g,a) : tau := b | ((a & g) | (x & g'))"
+		});
+	}
+
+	for (const auto& src : prelude) {
+		typename tau::get_options opts;
+		opts.parse = { .start = tau::rec_relation };
+		opts.definition_heads = defs.get_definition_heads();
+		opts.global_scope = defs.get_global_scope();
+		opts.context = &ctx;
+
+		tref parsed = tau::get(src, opts);
+		if (!parsed) {
+			TAU_LOG_ERROR << "Failed to parse finite table builtin: " << src;
+			return false;
+		}
+		auto rules = get_rec_relations<node>(ctx, parsed);
+		if (rules.size() != 1) {
+			TAU_LOG_ERROR << "Expected exactly one finite table builtin rule: " << src;
+			return false;
+		}
+		defs.add(rules.front().first, rules.front().second);
+	}
+	loaded = true;
+	return true;
+}
+
+template <NodeType node>
+bool ensure_loaded_if_enabled() {
+	if (!enabled()) return true;
+	return ensure_loaded<node>();
+}
+
+} // namespace idni::tau_lang::finite_table_builtins
+
+#endif // __IDNI__TAU__FINITE_TABLE_BUILTINS_H__
