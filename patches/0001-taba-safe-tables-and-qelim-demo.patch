+template <NodeType node>
+struct bool_expr {
+	enum kind_t { cnst, var, neg, land, lor };
+	kind_t kind;
+	bool value = false;
+	std::string name{};
+	std::shared_ptr<bool_expr> left{};
+	std::shared_ptr<bool_expr> right{};
+};
+
+template <NodeType node>
+using bexpr = std::shared_ptr<bool_expr<node>>;
+
+template <NodeType node>
+size_t leading_exists_count(tref fm) {
+	using tau = tree<node>;
+	size_t count = 0;
+	while (fm) {
+		const auto& t = tau::get(fm);
+		if (!t.is(tau::wff) || !t.child_is(tau::wff_ex)) break;
+		count += 1;
+		fm = t[0].second();
+	}
+	return count;
+}
+
+template <NodeType node>
+bool has_nonzero_equality_atom(tref fm) {
+	using tau = tree<node>;
+	const auto& t = tau::get(fm);
+	if (!t.is(tau::wff)) return false;
+	if (t.child_is(tau::wff_ex))
+		return has_nonzero_equality_atom<node>(tau::get(fm)[0].second());
+	if (t.child_is(tau::wff_neg))
+		return has_nonzero_equality_atom<node>(tau::get(fm)[0].first());
+	if (t.child_is(tau::wff_and) || t.child_is(tau::wff_or))
+		return has_nonzero_equality_atom<node>(tau::get(fm)[0].first())
+			|| has_nonzero_equality_atom<node>(tau::get(fm)[0].second());
+	if (t.child_is(tau::bf_eq) || t.child_is(tau::bf_neq)) {
+		tref l = tau::get(fm)[0].first();
+		tref r = tau::get(fm)[0].second();
+		return !tau::get(l).equals_0() && !tau::get(r).equals_0();
+	}
+	return false;
+}
+
+template <NodeType node>
+bool reject_auto_tau_shape(tref fm, size_t* quantified = nullptr,
+	size_t* free = nullptr, int_t* nodes = nullptr)
+{
+	if (!auto_enabled() || !raw_auto_guard_enabled()) return false;
+	const size_t q = leading_exists_count<node>(fm);
+	const size_t f = get_free_vars<node>(fm).size();
+	const int_t n = node_count<node>(fm);
+	if (quantified) *quantified = q;
+	if (free) *free = f;
+	if (nodes) *nodes = n;
+	if (q < 6) return false;
+	return f <= q + 1;
+}
+
+template <NodeType node>
+bexpr<node> make_const(bool value) {
+	static bexpr<node> t = std::make_shared<bool_expr<node>>(bool_expr<node>{
+		bool_expr<node>::cnst, true, {}, nullptr, nullptr });
+	static bexpr<node> f = std::make_shared<bool_expr<node>>(bool_expr<node>{
+		bool_expr<node>::cnst, false, {}, nullptr, nullptr });
+	return value ? t : f;
+}
+
+template <NodeType node>
+std::string repr(const bexpr<node>& e);
+
+template <NodeType node>
+bexpr<node> make_var(const std::string& name) {
+	return std::make_shared<bool_expr<node>>(bool_expr<node>{
+		bool_expr<node>::var, false, name, nullptr, nullptr });
+}
+
+template <NodeType node>
+bexpr<node> make_not(const bexpr<node>& e) {
+	if (e->kind == bool_expr<node>::cnst) return make_const<node>(!e->value);
+	if (e->kind == bool_expr<node>::neg) return e->left;
+	return std::make_shared<bool_expr<node>>(bool_expr<node>{
+		bool_expr<node>::neg, false, {}, e, nullptr });
+}
+
+template <NodeType node>
+bool same_expr(const bexpr<node>& a, const bexpr<node>& b) {
+	return repr<node>(a) == repr<node>(b);
+}
+
+template <NodeType node>
+bool is_neg_of(const bexpr<node>& a, const bexpr<node>& b) {
+	return same_expr<node>(a, make_not<node>(b));
+}
+
+template <NodeType node>
+std::string repr(const bexpr<node>& e) {
+	switch (e->kind) {
+		case bool_expr<node>::cnst: return e->value ? "T" : "F";
+		case bool_expr<node>::var: return e->name;
+		case bool_expr<node>::neg: return "!(" + repr<node>(e->left) + ")";
+		case bool_expr<node>::land: return "(" + repr<node>(e->left) + "&&" + repr<node>(e->right) + ")";
+		case bool_expr<node>::lor: return "(" + repr<node>(e->left) + "||" + repr<node>(e->right) + ")";
+	}
+	return "?";
+}
+
+template <NodeType node>
+bexpr<node> make_and(bexpr<node> l, bexpr<node> r) {
+	if (l->kind == bool_expr<node>::cnst && !l->value) return make_const<node>(false);
+	if (r->kind == bool_expr<node>::cnst && !r->value) return make_const<node>(false);
+	if (l->kind == bool_expr<node>::cnst && l->value) return r;
+	if (r->kind == bool_expr<node>::cnst && r->value) return l;
+	if (same_expr<node>(l, r)) return l;
+	if (is_neg_of<node>(l, r) || is_neg_of<node>(r, l)) return make_const<node>(false);
+	if (repr<node>(r) < repr<node>(l)) std::swap(l, r);
+	return std::make_shared<bool_expr<node>>(bool_expr<node>{
+		bool_expr<node>::land, false, {}, l, r });
+}
+
+template <NodeType node>
+bexpr<node> make_or(bexpr<node> l, bexpr<node> r) {
+	if (l->kind == bool_expr<node>::cnst && l->value) return make_const<node>(true);
+	if (r->kind == bool_expr<node>::cnst && r->value) return make_const<node>(true);
+	if (l->kind == bool_expr<node>::cnst && !l->value) return r;
+	if (r->kind == bool_expr<node>::cnst && !r->value) return l;
+	if (same_expr<node>(l, r)) return l;
+	if (is_neg_of<node>(l, r) || is_neg_of<node>(r, l)) return make_const<node>(true);
+	if (repr<node>(r) < repr<node>(l)) std::swap(l, r);
+	return std::make_shared<bool_expr<node>>(bool_expr<node>{
+		bool_expr<node>::lor, false, {}, l, r });
+}
+
+template <NodeType node>
+bexpr<node> normalize_ac(const bexpr<node>& e);
+
+template <NodeType node>
+void append_ac_child(const bexpr<node>& e,
+	typename bool_expr<node>::kind_t kind,
+	std::vector<bexpr<node>>& out)
+{
+	auto normalized = normalize_ac<node>(e);
+	if (normalized->kind == kind) {
+		append_ac_child<node>(normalized->left, kind, out);
+		append_ac_child<node>(normalized->right, kind, out);
+		return;
+	}
+	out.push_back(normalized);
+}
+
+template <NodeType node>
+bexpr<node> rebuild_ac(typename bool_expr<node>::kind_t kind,
+	std::vector<bexpr<node>>& terms)
+{
+	const bool is_and = kind == bool_expr<node>::land;
+	struct keyed_term {
+		std::string key;
+		std::string neg_key;
+		bexpr<node> expr;
+	};
+	std::vector<keyed_term> keyed;
+	keyed.reserve(terms.size());
+	for (const auto& term : terms) {
+		if (term->kind == bool_expr<node>::cnst) {
+			if (is_and && !term->value) return make_const<node>(false);
+			if (!is_and && term->value) return make_const<node>(true);
+			continue;
+		}
+		keyed.push_back(keyed_term{
+			repr<node>(term),
+			repr<node>(make_not<node>(term)),
+			term
+		});
+	}
+
+	std::sort(keyed.begin(), keyed.end(), [](const auto& a, const auto& b) {
+		return a.key < b.key;
+	});
+
+	std::vector<bexpr<node>> unique;
+	unique.reserve(keyed.size());
+	std::unordered_set<std::string> seen;
+	for (const auto& term : keyed) {
+		if (seen.contains(term.neg_key))
+			return make_const<node>(!is_and);
+		if (seen.insert(term.key).second)
+			unique.push_back(term.expr);
+	}
+
+	bexpr<node> out = make_const<node>(is_and);
+	for (const auto& term : unique)
+		out = is_and ? make_and<node>(out, term) : make_or<node>(out, term);
+	return out;
+}
+
+template <NodeType node>
+bexpr<node> normalize_ac(const bexpr<node>& e) {
+	switch (e->kind) {
+		case bool_expr<node>::cnst:
+		case bool_expr<node>::var:
+			return e;
+		case bool_expr<node>::neg:
+			return make_not<node>(normalize_ac<node>(e->left));
+		case bool_expr<node>::land:
+		case bool_expr<node>::lor: {
+			std::vector<bexpr<node>> terms;
+			append_ac_child<node>(e->left, e->kind, terms);
+			append_ac_child<node>(e->right, e->kind, terms);
+			return rebuild_ac<node>(e->kind, terms);
+		}
+	}
+	return e;
+}
+
+template <NodeType node>
+void collect_support(const bexpr<node>& e, std::set<std::string>& out) {
+	switch (e->kind) {
+		case bool_expr<node>::cnst: return;
+		case bool_expr<node>::var: out.insert(e->name); return;
+		case bool_expr<node>::neg: collect_support<node>(e->left, out); return;
+		case bool_expr<node>::land:
+		case bool_expr<node>::lor:
+			collect_support<node>(e->left, out);
+			collect_support<node>(e->right, out);
+			return;
+	}
+}
+
+template <NodeType node>
+struct kb_rewrite_stats {
+	size_t steps = 0;
+	size_t demorgan = 0;
+	size_t absorption = 0;
+	size_t discarded = 0;
+	size_t guard_absorption = 0;
+	size_t guard_demorgan = 0;
+	size_t guard_double_compl = 0;
+	size_t guard_ran = 0;
+	size_t before_nodes = 0;
+	size_t after_nodes = 0;
+};
+
+template <NodeType node>
+size_t expr_nodes(const bexpr<node>& e) {
+	switch (e->kind) {
+		case bool_expr<node>::cnst:
+		case bool_expr<node>::var:
+			return 1;
+		case bool_expr<node>::neg:
+			return 1 + expr_nodes<node>(e->left);
+		case bool_expr<node>::land:
+		case bool_expr<node>::lor:
+			return 1 + expr_nodes<node>(e->left) + expr_nodes<node>(e->right);
+	}
+	return 1;
+}
+
+template <NodeType node>
+bool is_or_with_child(const bexpr<node>& e, const bexpr<node>& child) {
+	return e->kind == bool_expr<node>::lor &&
+		(same_expr<node>(e->left, child) || same_expr<node>(e->right, child));
+}
+
+template <NodeType node>
+bool is_and_with_child(const bexpr<node>& e, const bexpr<node>& child) {
+	return e->kind == bool_expr<node>::land &&
+		(same_expr<node>(e->left, child) || same_expr<node>(e->right, child));
+}
+
+template <NodeType node>
+void scan_kb_opportunities(const bexpr<node>& e, kb_rewrite_stats<node>& stats) {
+	switch (e->kind) {
+		case bool_expr<node>::cnst:
+		case bool_expr<node>::var:
+			return;
+		case bool_expr<node>::neg:
+			if (e->left->kind == bool_expr<node>::neg)
+				stats.guard_double_compl += 1;
+			if (e->left->kind == bool_expr<node>::land ||
+				e->left->kind == bool_expr<node>::lor)
+				stats.guard_demorgan += 1;
+			scan_kb_opportunities<node>(e->left, stats);
+			return;
+		case bool_expr<node>::land:
+			if (is_or_with_child<node>(e->right, e->left) ||
+				is_or_with_child<node>(e->left, e->right))
+				stats.guard_absorption += 1;
+			scan_kb_opportunities<node>(e->left, stats);
+			scan_kb_opportunities<node>(e->right, stats);
+			return;
+		case bool_expr<node>::lor:
+			if (is_and_with_child<node>(e->right, e->left) ||
+				is_and_with_child<node>(e->left, e->right))
+				stats.guard_absorption += 1;
+			scan_kb_opportunities<node>(e->left, stats);
+			scan_kb_opportunities<node>(e->right, stats);
+			return;
+	}
+}
+
+template <NodeType node>
+bexpr<node> normalize_kb_rec(const bexpr<node>& e, kb_rewrite_stats<node>* stats) {
+	switch (e->kind) {
+		case bool_expr<node>::cnst:
+		case bool_expr<node>::var:
+			return e;
+		case bool_expr<node>::neg: {
+			auto a = normalize_kb_rec<node>(e->left, stats);
+			if (a->kind == bool_expr<node>::neg) {
+				if (stats) stats->steps += 1;
+				return normalize_kb_rec<node>(a->left, stats);
+			}
+			if (a->kind == bool_expr<node>::land) {
+				if (stats) {
+					stats->steps += 1;
+					stats->demorgan += 1;
+				}
+				return normalize_kb_rec<node>(
+					make_or<node>(make_not<node>(a->left), make_not<node>(a->right)),
+					stats);
+			}
+			if (a->kind == bool_expr<node>::lor) {
+				if (stats) {
+					stats->steps += 1;
+					stats->demorgan += 1;
+				}
+				return normalize_kb_rec<node>(
+					make_and<node>(make_not<node>(a->left), make_not<node>(a->right)),
+					stats);
+			}
+			return make_not<node>(a);
+		}
+		case bool_expr<node>::land: {
+			auto l = normalize_kb_rec<node>(e->left, stats);
+			auto r = normalize_kb_rec<node>(e->right, stats);
+			if (is_or_with_child<node>(r, l)) {
+				if (stats) {
+					stats->steps += 1;
+					stats->absorption += 1;
+				}
+				return l;
+			}
+			if (is_or_with_child<node>(l, r)) {
+				if (stats) {
+					stats->steps += 1;
+					stats->absorption += 1;
+				}
+				return r;
+			}
+			return make_and<node>(l, r);
+		}
+		case bool_expr<node>::lor: {
+			auto l = normalize_kb_rec<node>(e->left, stats);
+			auto r = normalize_kb_rec<node>(e->right, stats);
+			if (is_and_with_child<node>(r, l)) {
+				if (stats) {
+					stats->steps += 1;
+					stats->absorption += 1;
+				}
+				return l;
+			}
+			if (is_and_with_child<node>(l, r)) {
+				if (stats) {
+					stats->steps += 1;
+					stats->absorption += 1;
+				}
+				return r;
+			}
+			return make_or<node>(l, r);
+		}
+	}
+	return e;
+}
+
+template <NodeType node>
+bexpr<node> normalize_kb(const bexpr<node>& e, kb_rewrite_stats<node>* stats) {
+	if (stats) stats->before_nodes = expr_nodes<node>(e);
+	if (stats) stats->guard_ran += 1;
+	bexpr<node> current = e;
+	for (size_t i = 0; i < 64; ++i) {
+		const std::string before = repr<node>(current);
+		bexpr<node> next = normalize_kb_rec<node>(current, stats);
+		const std::string after = repr<node>(next);
+		current = next;
+		if (after == before) break;
+	}
+	const size_t before_nodes = expr_nodes<node>(e);
+	const size_t after_nodes = expr_nodes<node>(current);
+	if (after_nodes > before_nodes) {
+		if (stats) {
+			stats->discarded += 1;
+			stats->after_nodes = before_nodes;
+		}
+		return e;
+	}
+	if (stats) stats->after_nodes = after_nodes;
+	return current;
+}
+
+template <NodeType node>
+struct preflight_metrics {
+	size_t tree_nodes = 0;
+	size_t unique_nodes = 0;
+	size_t support = 0;
+	size_t quantified = 0;
+	size_t free = 0;
+	size_t max_occurrence = 0;
+};
+
+template <NodeType node>
+void collect_preflight_stats(const bexpr<node>& e,
+	std::unordered_set<std::string>& unique_reprs,
+	std::unordered_map<std::string, size_t>& occurrences,
+	size_t& tree_nodes)
+{
+	tree_nodes += 1;
+	unique_reprs.insert(repr<node>(e));
+	switch (e->kind) {
+		case bool_expr<node>::cnst: return;
+		case bool_expr<node>::var:
+			occurrences[e->name] += 1;
+			return;
+		case bool_expr<node>::neg:
+			collect_preflight_stats<node>(
+				e->left, unique_reprs, occurrences, tree_nodes);
+			return;
+		case bool_expr<node>::land:
+		case bool_expr<node>::lor:
+			collect_preflight_stats<node>(
+				e->left, unique_reprs, occurrences, tree_nodes);
+			collect_preflight_stats<node>(
+				e->right, unique_reprs, occurrences, tree_nodes);
+			return;
+	}
+}
+
+template <NodeType node>
+preflight_metrics<node> compute_preflight_metrics(
+	const bexpr<node>& e,
+	const std::unordered_set<std::string>& quantified)
+{
+	std::unordered_set<std::string> unique_reprs;
+	std::unordered_map<std::string, size_t> occurrences;
+	size_t tree_nodes = 0;
+	collect_preflight_stats<node>(e, unique_reprs, occurrences, tree_nodes);
+
+	preflight_metrics<node> metrics;
+	metrics.tree_nodes = tree_nodes;
+	metrics.unique_nodes = unique_reprs.size();
+	metrics.support = occurrences.size();
+	metrics.quantified = quantified.size();
+	for (const auto& [name, count] : occurrences) {
+		if (!quantified.contains(name)) metrics.free += 1;
+		metrics.max_occurrence = std::max(metrics.max_occurrence, count);
+	}
+	return metrics;
+}
+
+template <NodeType node>
+bexpr<node> restrict_expr(const bexpr<node>& e, const std::string& var, bool value) {
+	switch (e->kind) {
+		case bool_expr<node>::cnst: return e;
+		case bool_expr<node>::var: return e->name == var ? make_const<node>(value) : e;
+		case bool_expr<node>::neg: return make_not<node>(restrict_expr<node>(e->left, var, value));
+		case bool_expr<node>::land: return make_and<node>(restrict_expr<node>(e->left, var, value), restrict_expr<node>(e->right, var, value));
+		case bool_expr<node>::lor: return make_or<node>(restrict_expr<node>(e->left, var, value), restrict_expr<node>(e->right, var, value));
+	}
+	return e;
+}
+
+template <NodeType node>
+void flatten_and(const bexpr<node>& e, std::vector<bexpr<node>>& out) {
+	if (e->kind == bool_expr<node>::land) {
+		flatten_and<node>(e->left, out);
+		flatten_and<node>(e->right, out);
+		return;
+	}
+	out.push_back(e);
+}
+
+template <NodeType node>
+bexpr<node> conjoin(const std::vector<bexpr<node>>& factors) {
+	bexpr<node> out = make_const<node>(true);
+	for (const auto& factor : factors)
+		out = make_and<node>(out, factor);
+	return out;
+}
+
+template <NodeType node>
+std::unordered_set<std::string> support_set(const bexpr<node>& e) {
+	std::set<std::string> ordered;
+	collect_support<node>(e, ordered);
+	return { ordered.begin(), ordered.end() };
+}
+
+template <NodeType node>
+void flatten_or(const bexpr<node>& e, std::vector<bexpr<node>>& out) {
+	if (e->kind == bool_expr<node>::lor) {
+		flatten_or<node>(e->left, out);
+		flatten_or<node>(e->right, out);
+		return;
+	}
+	out.push_back(e);
+}
+
+template <NodeType node>
+struct cnf_lit {
+	std::string name;
+	bool positive = true;
+};
+
+template <NodeType node>
+using cnf_clause = std::vector<cnf_lit<node>>;
+
+template <NodeType node>
+std::optional<cnf_lit<node>> literal_of(const bexpr<node>& e) {
+	if (e->kind == bool_expr<node>::var) return cnf_lit<node>{ e->name, true };
+	if (e->kind == bool_expr<node>::neg &&
+		e->left->kind == bool_expr<node>::var)
+		return cnf_lit<node>{ e->left->name, false };
+	return {};
+}
+
+template <NodeType node>
+std::optional<cnf_clause<node>> extract_clause(const bexpr<node>& e,
+	bool* tautological = nullptr)
+{
+	if (tautological) *tautological = false;
+	std::vector<bexpr<node>> terms;
+	flatten_or<node>(e, terms);
+	std::unordered_map<std::string, int> seen;
+	cnf_clause<node> clause;
+	for (const auto& term : terms) {
+		if (term->kind == bool_expr<node>::cnst) {
+			if (term->value) {
+				if (tautological) *tautological = true;
+				return cnf_clause<node>{};
+			}
+			continue;
+		}
+		auto lit = literal_of<node>(term);
+		if (!lit) return {};
+		int polarity = lit->positive ? 1 : -1;
+		if (auto it = seen.find(lit->name); it != seen.end()) {
+			if (it->second != polarity) {
+				if (tautological) *tautological = true;
+				return cnf_clause<node>{};
+			}
+			continue;
+		}
+		seen.emplace(lit->name, polarity);
+		clause.push_back(*lit);
+	}
+	return clause;
+}
+
+template <NodeType node>
+std::optional<std::vector<cnf_clause<node>>> extract_cnf(const bexpr<node>& e) {
+	std::vector<bexpr<node>> factors;
+	flatten_and<node>(e, factors);
+	std::vector<cnf_clause<node>> clauses;
+	for (const auto& factor : factors) {
+		if (factor->kind == bool_expr<node>::cnst) {
+			if (factor->value) continue;
+			clauses.push_back({});
+			continue;
+		}
+		bool tautological = false;
+		auto clause = extract_clause<node>(factor, &tautological);
+		if (!clause) return {};
+		if (tautological) continue;
+		clauses.push_back(*clause);
+	}
+	return clauses;
+}
+
+template <NodeType node>
+bexpr<node> literal_to_expr(const cnf_lit<node>& lit) {
+	auto atom = make_var<node>(lit.name);
+	return lit.positive ? atom : make_not<node>(atom);
+}
+
+template <NodeType node>
+bexpr<node> clause_to_expr(const cnf_clause<node>& clause) {
+	if (clause.empty()) return make_const<node>(false);
+	bexpr<node> out = make_const<node>(false);
+	for (const auto& lit : clause)
+		out = make_or<node>(out, literal_to_expr<node>(lit));
+	return out;
+}
+
+template <NodeType node>
+bexpr<node> cnf_to_expr(const std::vector<cnf_clause<node>>& clauses) {
+	bexpr<node> out = make_const<node>(true);
+	for (const auto& clause : clauses)
+		out = make_and<node>(out, clause_to_expr<node>(clause));
+	return out;
+}
+
+template <NodeType node>
+bool clause_has_var(const cnf_clause<node>& clause, const std::string& name) {
+	for (const auto& lit : clause)
+		if (lit.name == name) return true;
+	return false;
+}
+
+template <NodeType node>
+bool clause_has_lit(const cnf_clause<node>& clause,
+	const std::string& name,
+	bool positive)
+{
+	for (const auto& lit : clause)
+		if (lit.name == name && lit.positive == positive) return true;
+	return false;
+}
+
+template <NodeType node>
+bool resolvent_is_tautological(const cnf_clause<node>& positive_clause,
+	const cnf_clause<node>& negative_clause,
+	const std::string& variable)
+{
+	std::unordered_map<std::string, int> seen;
+	const auto add_lit = [&](const cnf_lit<node>& lit) {
+		if (lit.name == variable) return false;
+		int polarity = lit.positive ? 1 : -1;
+		if (auto it = seen.find(lit.name); it != seen.end())
+			return it->second != polarity;
+		seen.emplace(lit.name, polarity);
+		return false;
+	};
+	for (const auto& lit : positive_clause)
+		if (add_lit(lit)) return true;
+	for (const auto& lit : negative_clause)
+		if (add_lit(lit)) return true;
+	return false;
+}
+
+template <NodeType node>
+cnf_clause<node> canonical_clause(cnf_clause<node> clause) {
+	std::sort(clause.begin(), clause.end(), [](const auto& a, const auto& b) {
+		if (a.name != b.name) return a.name < b.name;
+		return a.positive > b.positive;
+	});
+	return clause;
+}
+
+template <NodeType node>
+std::string clause_key(const cnf_clause<node>& clause) {
+	std::string out;
+	for (const auto& lit : canonical_clause<node>(clause)) {
+		out += lit.positive ? "+" : "-";
+		out += lit.name;
+		out += ";";
+	}
+	return out;
+}
+
+template <NodeType node>
+std::optional<cnf_clause<node>> normalize_clause(const cnf_clause<node>& clause) {
+	std::unordered_map<std::string, int> seen;
+	cnf_clause<node> out;
+	for (const auto& lit : clause) {
+		int polarity = lit.positive ? 1 : -1;
+		if (auto it = seen.find(lit.name); it != seen.end()) {
+			if (it->second != polarity) return {};
+			continue;
+		}
+		seen.emplace(lit.name, polarity);
+		out.push_back(lit);
+	}
+	return canonical_clause<node>(out);
+}
+
+template <NodeType node>
+std::optional<cnf_clause<node>> resolvent_clause(const cnf_clause<node>& positive_clause,
+	const cnf_clause<node>& negative_clause,
+	const std::string& variable)
+{
+	cnf_clause<node> raw;
+	for (const auto& lit : positive_clause)
+		if (lit.name != variable) raw.push_back(lit);
+	for (const auto& lit : negative_clause)
+		if (lit.name != variable) raw.push_back(lit);
+	return normalize_clause<node>(raw);
+}
+
+template <NodeType node>
+void add_clause_unique(std::vector<cnf_clause<node>>& clauses,
+	std::unordered_set<std::string>& keys,
+	const cnf_clause<node>& clause)
+{
+	cnf_clause<node> canonical = canonical_clause<node>(clause);
+	std::string key = clause_key<node>(canonical);
+	if (keys.insert(key).second) clauses.push_back(std::move(canonical));
+}
+
+template <NodeType node>
+bool clause_subsumes(const cnf_clause<node>& small, const cnf_clause<node>& large) {
+	size_t i = 0;
+	size_t j = 0;
+	while (i < small.size() && j < large.size()) {
+		const auto& a = small[i];
+		const auto& b = large[j];
+		if (a.name == b.name && a.positive == b.positive) {
+			++i;
+			++j;
+			continue;
+		}
+		if (a.name < b.name || (a.name == b.name && a.positive > b.positive))
+			return false;
+		++j;
+	}
+	return i == small.size();
+}
+
+template <NodeType node>
+void rebuild_clause_keys(const std::vector<cnf_clause<node>>& clauses,
+	std::unordered_set<std::string>& keys)
+{
+	keys.clear();
+	for (const auto& clause : clauses)
+		keys.insert(clause_key<node>(clause));
+}
+
+template <NodeType node>
+bool add_clause_subsuming(std::vector<cnf_clause<node>>& clauses,
+	std::unordered_set<std::string>& keys,
+	const cnf_clause<node>& clause,
+	size_t* removed = nullptr)
+{
+	cnf_clause<node> canonical = canonical_clause<node>(clause);
+	std::string key = clause_key<node>(canonical);
+	if (keys.contains(key)) return false;
+	for (const auto& existing : clauses) {
+		if (clause_subsumes<node>(existing, canonical)) {
+			if (removed) *removed += 1;
+			return false;
+		}
+	}
+
+	std::vector<cnf_clause<node>> next;
+	next.reserve(clauses.size() + 1);
+	size_t removed_count = 0;
+	for (auto& existing : clauses) {
+		if (clause_subsumes<node>(canonical, existing)) {
+			removed_count += 1;
+			continue;
+		}
+		next.push_back(std::move(existing));
+	}
+	next.push_back(std::move(canonical));
+	clauses = std::move(next);
+	rebuild_clause_keys<node>(clauses, keys);
+	if (removed) *removed += removed_count;
+	return true;
+}
+
+template <NodeType node>
+struct polarity_count {
+	size_t positive = 0;
+	size_t negative = 0;
+};
+
+template <NodeType node>
+void collect_polarities(const bexpr<node>& e,
+	std::unordered_map<std::string, polarity_count<node>>& out,
+	bool positive = true)
+{
+	switch (e->kind) {
+		case bool_expr<node>::cnst: return;
+		case bool_expr<node>::var:
+			if (positive) out[e->name].positive += 1;
+			else out[e->name].negative += 1;
+			return;
+		case bool_expr<node>::neg:
+			collect_polarities<node>(e->left, out, !positive);
+			return;
+		case bool_expr<node>::land:
+		case bool_expr<node>::lor:
+			collect_polarities<node>(e->left, out, positive);
+			collect_polarities<node>(e->right, out, positive);
+			return;
+	}
+}
+
+template <NodeType node>
+struct compile_state {
+	std::unordered_map<std::string, size_t> types;
+	std::vector<std::string> appearance_order;
+	std::unordered_set<std::string> quantified;
+	std::unordered_map<std::string, size_t> occurrence_count;
+	std::unordered_map<std::string, size_t> first_seen;
+	std::unordered_map<std::string, size_t> last_seen;
+	size_t seen_index = 0;
+};
+
+template <NodeType node>
+bool reject_auto_high_duplication_shape(const bexpr<node>& e,
+	const compile_state<node>& st)
+{
+	if (!auto_enabled() || !dup_auto_guard_enabled()) return false;
+	auto metrics = compute_preflight_metrics<node>(e, st.quantified);
+	if (metrics.quantified < 6) return false;
+	if (metrics.unique_nodes == 0) return false;
+	if (metrics.free > metrics.quantified + 1) return false;
+	if (metrics.max_occurrence < 64) return false;
+	return metrics.tree_nodes >= metrics.unique_nodes * 10;
+}
+
+template <NodeType node>
+bool reject_auto_high_duplication_shape(
+	const preflight_metrics<node>& metrics)
+{
+	if (metrics.quantified < 6) return false;
+	if (metrics.unique_nodes == 0) return false;
+	if (metrics.free > metrics.quantified + 1) return false;
+	if (metrics.max_occurrence < 64) return false;
+	return metrics.tree_nodes >= metrics.unique_nodes * 10;
+}
+
+template <NodeType node>
+bool has_quantified_support(const bexpr<node>& e, const compile_state<node>& st) {
+	auto supp = support_set<node>(e);
+	for (const auto& name : supp)
+		if (st.quantified.contains(name)) return true;
+	return false;
+}
+
+template <NodeType node>
+bexpr<node> drop_pure_quantified(const bexpr<node>& e,
+	const compile_state<node>& st,
+	size_t* pure_drops = nullptr)
+{
+	bexpr<node> current = e;
+	std::unordered_set<std::string> dropped;
+	bool changed = true;
+	while (changed) {
+		changed = false;
+		std::unordered_map<std::string, polarity_count<node>> polarities;
+		collect_polarities<node>(current, polarities);
+		std::vector<std::pair<std::string, bool>> substitutions;
+		for (const auto& name : st.appearance_order) {
+			if (!st.quantified.contains(name) || dropped.contains(name)) continue;
+			auto it = polarities.find(name);
+			if (it == polarities.end()) {
+				dropped.insert(name);
+				continue;
+			}
+			const auto& count = it->second;
+			if (count.positive > 0 && count.negative == 0)
+				substitutions.push_back({ name, true });
+			else if (count.negative > 0 && count.positive == 0)
+				substitutions.push_back({ name, false });
+		}
+		for (const auto& [name, value] : substitutions) {
+			current = restrict_expr<node>(current, name, value);
+			dropped.insert(name);
+			if (pure_drops) *pure_drops += 1;
+			changed = true;
+		}
+	}
+	return current;
+}
+
+template <NodeType node>
+bexpr<node> drop_blocked_quantified_cnf(const bexpr<node>& e,
+	const compile_state<node>& st,
+	size_t* blocked_drops = nullptr,
+	size_t* blocked_clause_drops = nullptr)
+{
+	auto extracted = extract_cnf<node>(e);
+	if (!extracted) return e;
+	std::vector<cnf_clause<node>> clauses = *extracted;
+	std::unordered_set<std::string> dropped;
+	bool changed = true;
+	while (changed) {
+		changed = false;
+		for (const auto& name : st.appearance_order) {
+			if (!st.quantified.contains(name) || dropped.contains(name)) continue;
+			std::vector<size_t> positive_clauses;
+			std::vector<size_t> negative_clauses;
+			for (size_t i = 0; i < clauses.size(); ++i) {
+				if (clause_has_lit<node>(clauses[i], name, true))
+					positive_clauses.push_back(i);
+				if (clause_has_lit<node>(clauses[i], name, false))
+					negative_clauses.push_back(i);
+			}
+			if (positive_clauses.empty() || negative_clauses.empty()) continue;
+			bool all_resolvents_tautological = true;
+			for (size_t p : positive_clauses) {
+				for (size_t n : negative_clauses) {
+					if (!resolvent_is_tautological<node>(clauses[p], clauses[n], name)) {
+						all_resolvents_tautological = false;
+						break;
+					}
+				}
+				if (!all_resolvents_tautological) break;
+			}
+			if (!all_resolvents_tautological) continue;
+
+			std::vector<cnf_clause<node>> kept;
+			kept.reserve(clauses.size());
+			size_t removed = 0;
+			for (const auto& clause : clauses) {
+				if (clause_has_var<node>(clause, name)) {
+					removed += 1;
+					continue;
+				}
+				kept.push_back(clause);
+			}
+			clauses = std::move(kept);
+			dropped.insert(name);
+			if (blocked_drops) *blocked_drops += 1;
+			if (blocked_clause_drops) *blocked_clause_drops += removed;
+			changed = true;
+			break;
+		}
+	}
+	return cnf_to_expr<node>(clauses);
+}
+
+template <NodeType node>
+bexpr<node> distribute_quantified_cnf_under_cap(const bexpr<node>& e,
+	const compile_state<node>& st,
+	size_t cap,
+	size_t* dp_drops = nullptr,
+	size_t* dp_resolvents = nullptr,
+	size_t* dp_clause_drops = nullptr,
+	size_t* dp_subsumed = nullptr)
+{
+	auto extracted = extract_cnf<node>(e);
+	if (!extracted) return e;
+	std::vector<cnf_clause<node>> clauses;
+	std::unordered_set<std::string> initial_keys;
+	for (const auto& clause : *extracted) {
+		auto normalized = normalize_clause<node>(clause);
+		if (!normalized) continue;
+		if (subsume_enabled())
+			add_clause_subsuming<node>(clauses, initial_keys, *normalized, dp_subsumed);
+		else
+			add_clause_unique<node>(clauses, initial_keys, *normalized);
+	}
+
+	std::unordered_set<std::string> dropped;
+	bool changed = true;
+	while (changed) {
+		changed = false;
+		for (const auto& name : st.appearance_order) {
+			if (!st.quantified.contains(name) || dropped.contains(name)) continue;
+			std::vector<size_t> positive_clauses;
+			std::vector<size_t> negative_clauses;
+			for (size_t i = 0; i < clauses.size(); ++i) {
+				if (clause_has_lit<node>(clauses[i], name, true))
+					positive_clauses.push_back(i);
+				if (clause_has_lit<node>(clauses[i], name, false))
+					negative_clauses.push_back(i);
+			}
+			if (positive_clauses.empty() && negative_clauses.empty()) continue;
+
+			std::vector<cnf_clause<node>> resolvents;
+			std::unordered_set<std::string> resolvent_keys;
+			size_t local_subsumed = 0;
+			bool over_cap = false;
+			for (size_t p : positive_clauses) {
+				for (size_t n : negative_clauses) {
+					auto resolvent = resolvent_clause<node>(clauses[p], clauses[n], name);
+					if (!resolvent) continue;
+					if (subsume_enabled())
+						add_clause_subsuming<node>(resolvents, resolvent_keys, *resolvent, &local_subsumed);
+					else
+						add_clause_unique<node>(resolvents, resolvent_keys, *resolvent);
+					if (resolvents.size() > cap) {
+						over_cap = true;
+						break;
+					}
+				}
+				if (over_cap) break;
+			}
+			if (over_cap) continue;
+
+			std::vector<cnf_clause<node>> next;
+			std::unordered_set<std::string> next_keys;
+			size_t removed = 0;
+			for (const auto& clause : clauses) {
+				if (clause_has_var<node>(clause, name)) {
+					removed += 1;
+					continue;
+				}
+				if (subsume_enabled())
+					add_clause_subsuming<node>(next, next_keys, clause, dp_subsumed);
+				else
+					add_clause_unique<node>(next, next_keys, clause);
+			}
+			for (const auto& clause : resolvents)
+				if (subsume_enabled())
+					add_clause_subsuming<node>(next, next_keys, clause, dp_subsumed);
+				else
+					add_clause_unique<node>(next, next_keys, clause);
+			clauses = std::move(next);
+			dropped.insert(name);
+			if (dp_drops) *dp_drops += 1;
+			if (dp_resolvents) *dp_resolvents += resolvents.size();
+			if (dp_clause_drops) *dp_clause_drops += removed;
+			if (dp_subsumed) *dp_subsumed += local_subsumed;
+			changed = true;
+			break;
+		}
+	}
+	return cnf_to_expr<node>(clauses);
+}
+
+template <NodeType node>
+struct expr_component {
+	std::vector<bexpr<node>> factors;
+	std::unordered_set<std::string> quantified;
+};
+
+inline int find_parent(std::vector<int>& parent, int idx) {
+	if (parent[idx] == idx) return idx;
+	parent[idx] = find_parent(parent, parent[idx]);
+	return parent[idx];
+}
+
+inline void union_parent(std::vector<int>& parent, int a, int b) {
+	int ra = find_parent(parent, a);
+	int rb = find_parent(parent, b);
+	if (ra != rb) parent[rb] = ra;
+}
+
+template <NodeType node>
+std::vector<expr_component<node>> quantified_components(
+	const bexpr<node>& e,
+	const compile_state<node>& st,
+	std::vector<bexpr<node>>& free_factors)
+{
+	std::vector<bexpr<node>> factors;
+	flatten_and<node>(e, factors);
+	std::vector<std::unordered_set<std::string>> qsets(factors.size());
+	std::vector<int> parent(factors.size());
+	for (size_t i = 0; i < factors.size(); ++i) parent[i] = static_cast<int>(i);
+
+	std::unordered_map<std::string, int> first_factor_by_qvar;
+	for (size_t i = 0; i < factors.size(); ++i) {
+		auto supp = support_set<node>(factors[i]);
+		for (const auto& name : supp)
+			if (st.quantified.contains(name)) qsets[i].insert(name);
+		if (qsets[i].empty()) {
+			free_factors.push_back(factors[i]);
+			continue;
+		}
+		for (const auto& name : qsets[i]) {
+			if (auto it = first_factor_by_qvar.find(name); it != first_factor_by_qvar.end())
+				union_parent(parent, static_cast<int>(i), it->second);
+			else first_factor_by_qvar.emplace(name, static_cast<int>(i));
+		}
+	}
+
+	std::vector<expr_component<node>> groups;
+	std::unordered_map<int, size_t> root_to_group;
+	for (size_t i = 0; i < factors.size(); ++i) {
+		if (qsets[i].empty()) continue;
+		int root = find_parent(parent, static_cast<int>(i));
+		size_t group_idx = 0;
+		if (auto it = root_to_group.find(root); it != root_to_group.end()) {
+			group_idx = it->second;
+		} else {
+			group_idx = groups.size();
+			root_to_group.emplace(root, group_idx);
+			groups.push_back({});
+		}
+		groups[group_idx].factors.push_back(factors[i]);
+		for (const auto& name : qsets[i]) groups[group_idx].quantified.insert(name);
+	}
+	return groups;
+}
+
+template <NodeType node>
+void note_var(compile_state<node>& st, const std::string& name, size_t type_id) {
+	if (!st.types.contains(name)) {
+		st.types.emplace(name, type_id);
+		st.appearance_order.push_back(name);
+		st.first_seen.emplace(name, st.seen_index);
+	}
+	st.occurrence_count[name] += 1;
+	st.last_seen[name] = st.seen_index;
+	st.seen_index += 1;
+}
+
+inline std::string order_mode() {
+	const char* env = std::getenv("TAU_QELIM_BDD_ORDER");
+	if (!env) {
+		if (auto_enabled()) return "quantified_first_density";
+		return "quantified_first_appearance";
+	}
+	return std::string(env);
+}
+
+template <NodeType node>
+std::vector<std::string> choose_order(const compile_state<node>& st) {
+	std::vector<std::string> names = st.appearance_order;
+	std::unordered_map<std::string, size_t> appearance_index;
+	for (size_t i = 0; i < st.appearance_order.size(); ++i)
+		appearance_index.emplace(st.appearance_order[i], i);
+	const auto span = [&](const std::string& name) {
+		size_t first = st.first_seen.contains(name) ? st.first_seen.at(name) : 0;
+		size_t last = st.last_seen.contains(name) ? st.last_seen.at(name) : first;
+		return last >= first ? (last - first) : size_t{0};
+	};
+	const auto last_seen = [&](const std::string& name) {
+		return st.last_seen.contains(name) ? st.last_seen.at(name) : size_t{0};
+	};
+	const auto occurrence = [&](const std::string& name) {
+		return st.occurrence_count.contains(name) ? st.occurrence_count.at(name) : size_t{0};
+	};
+	const auto tie_break = [&](const std::string& a, const std::string& b) {
+		return appearance_index.at(a) < appearance_index.at(b);
+	};
+	const auto freq_desc_then_appearance = [&](const std::string& a, const std::string& b) {
+		size_t ca = occurrence(a);
+		size_t cb = occurrence(b);
+		if (ca != cb) return ca > cb;
+		return tie_break(a, b);
+	};
+	const auto span_asc_then_appearance = [&](const std::string& a, const std::string& b) {
+		size_t sa = span(a);
+		size_t sb = span(b);
+		if (sa != sb) return sa < sb;
+		return tie_break(a, b);
+	};
+	const auto span_desc_then_appearance = [&](const std::string& a, const std::string& b) {
+		size_t sa = span(a);
+		size_t sb = span(b);
+		if (sa != sb) return sa > sb;
+		return tie_break(a, b);
+	};
+	const auto last_asc_then_appearance = [&](const std::string& a, const std::string& b) {
+		size_t la = last_seen(a);
+		size_t lb = last_seen(b);
+		if (la != lb) return la < lb;
+		return tie_break(a, b);
+	};
+	const auto density_desc_then_appearance = [&](const std::string& a, const std::string& b) {
+		size_t sa = span(a) + 1;
+		size_t sb = span(b) + 1;
+		size_t ca = occurrence(a);
+		size_t cb = occurrence(b);
+		size_t lhs = ca * sb;
+		size_t rhs = cb * sa;
+		if (lhs != rhs) return lhs > rhs;
+		return tie_break(a, b);
+	};
+	const auto by_name = [](const std::string& a, const std::string& b) { return a < b; };
+	const auto quantified_first = [&](auto within_group) {
+		std::stable_sort(names.begin(), names.end(), [&](const std::string& a, const std::string& b) {
+			bool aq = st.quantified.contains(a);
+			bool bq = st.quantified.contains(b);
+			if (aq != bq) return aq;
+			return within_group(a, b);
+		});
+		return names;
+	};
+	const std::string mode = order_mode();
+	if (mode == "appearance") return names;
+	if (mode == "free_first_appearance") {
+		std::stable_sort(names.begin(), names.end(), [&](const std::string& a, const std::string& b) {
+			bool aq = st.quantified.contains(a);
+			bool bq = st.quantified.contains(b);
+			if (aq != bq) return !aq;
+			return tie_break(a, b);
+		});
+		return names;
+	}
+	if (mode == "quantified_first_span_asc")
+		return quantified_first(span_asc_then_appearance);
+	if (mode == "quantified_first_span_desc")
+		return quantified_first(span_desc_then_appearance);
+	if (mode == "quantified_first_last")
+		return quantified_first(last_asc_then_appearance);
+	if (mode == "quantified_first_density")
+		return quantified_first(density_desc_then_appearance);
+	if (mode == "quantified_first_frequency") {
+		return quantified_first(freq_desc_then_appearance);
+	}
+	if (mode == "free_first_frequency") {
+		std::stable_sort(names.begin(), names.end(), [&](const std::string& a, const std::string& b) {
+			bool aq = st.quantified.contains(a);
+			bool bq = st.quantified.contains(b);
+			if (aq != bq) return !aq;
+			return freq_desc_then_appearance(a, b);
+		});
+		return names;
+	}
+	if (mode == "alphabetic") {
+		std::stable_sort(names.begin(), names.end(), by_name);
+		return names;
+	}
+	std::stable_sort(names.begin(), names.end(), [&](const std::string& a, const std::string& b) {
+		bool aq = st.quantified.contains(a);
+		bool bq = st.quantified.contains(b);
+		if (aq != bq) return aq;
+		return tie_break(a, b);
+	});
+	return names;
+}
+
+template <NodeType node>
+std::optional<std::pair<std::string, size_t>> extract_simple_var(tref term) {
+	using tau = tree<node>;
+	using tt = tau::traverser;
+	const auto& t = tau::get(term);
+	if (t.is(tau::variable)) return { { get_var_name<node>(term), t.get_ba_type() } };
+	if (t.is(tau::bf) && t.child_is(tau::variable)) {
+		tref v = tau::trim(term);
+		return { { get_var_name<node>(v), tau::get(v).get_ba_type() } };
+	}
+	if (auto v = tt(term) | tau::variable; v) {
+		const trefs& fv = get_free_vars<node>(term);
+		if (fv.size() == 1 && tau::get(fv[0]) == tau::get(v.value()))
+			return { { get_var_name<node>(v.value()), tau::get(v.value()).get_ba_type() } };
+	}
+	return {};
+}
+
+template <NodeType node>
+std::optional<bexpr<node>> compile_tau_formula(tref fm, compile_state<node>& st,
+	bool allow_leading_exists = true) {
+	using tau = tree<node>;
+	const auto& t = tau::get(fm);
+	if (!t.is(tau::wff)) return {};
+	if (t.equals_T()) return make_const<node>(true);
+	if (t.equals_F()) return make_const<node>(false);
+	if (t.child_is(tau::wff_ex)) {
+		if (!allow_leading_exists) return {};
+		tref var = tau::trim2(fm);
+		const std::string& name = get_var_name<node>(var);
+		if (st.quantified.contains(name)) return {};
+		note_var<node>(st, name, tau::get(var).get_ba_type());
+		st.quantified.insert(name);
+		return compile_tau_formula<node>(tau::get(fm)[0].second(), st, true);
+	}
+	if (t.child_is(tau::wff_neg)) {
+		auto inner = compile_tau_formula<node>(tau::get(fm)[0].first(), st, false);
+		if (!inner) return {};
+		return make_not<node>(*inner);
+	}
+	if (t.child_is(tau::wff_and)) {
+		auto l = compile_tau_formula<node>(tau::get(fm)[0].first(), st, false);
+		auto r = compile_tau_formula<node>(tau::get(fm)[0].second(), st, false);
+		if (!l || !r) return {};
+		return make_and<node>(*l, *r);
+	}
+	if (t.child_is(tau::wff_or)) {
+		auto l = compile_tau_formula<node>(tau::get(fm)[0].first(), st, false);
+		auto r = compile_tau_formula<node>(tau::get(fm)[0].second(), st, false);
+		if (!l || !r) return {};
+		return make_or<node>(*l, *r);
+	}
+	if (t.child_is(tau::bf_eq) || t.child_is(tau::bf_neq)) {
+		tref l = tau::get(fm)[0].first();
+		tref r = tau::get(fm)[0].second();
+		bool negated = t.child_is(tau::bf_neq);
+		if (tau::get(l).equals_0()) std::swap(l, r);
+		if (!tau::get(r).equals_0()) return {};
+		auto var = extract_simple_var<node>(l);
+		if (!var) return {};
+		note_var<node>(st, var->first, var->second);
+		auto atom = make_var<node>(var->first);
+		return negated ? make_not<node>(atom) : atom;
+	}
+	return {};
+}
+
+template <NodeType node>
+struct bdd_key {
+	std::string var;
+	int low = 0;
+	int high = 0;
+	auto operator<=>(const bdd_key&) const = default;
+};
+
+template <NodeType node>
+struct key_hash {
+	size_t operator()(const bdd_key<node>& k) const {
+		return std::hash<std::string>{}(k.var) ^
+			(std::hash<int>{}(k.low) << 1) ^
+			(std::hash<int>{}(k.high) << 2);
+	}
+};
+
+template <NodeType node>
+struct bdd_manager {
+	std::vector<std::string> order;
+	std::unordered_map<std::string, int> level;
+	std::unordered_map<bdd_key<node>, int, key_hash<node>> unique;
+	std::unordered_map<int, bdd_key<node>> nodes;
+	std::unordered_map<std::string, int> build_cache;
+	int next_id = 2;
+
+	explicit bdd_manager(std::vector<std::string> v) : order(std::move(v)) {
+		for (size_t i = 0; i < order.size(); ++i) level[order[i]] = static_cast<int>(i);
+	}
+
+	int mk(const std::string& var, int low, int high) {
+		if (low == high) return low;
+		bdd_key<node> key{ var, low, high };
+		auto it = unique.find(key);
+		if (it != unique.end()) return it->second;
+		int id = next_id++;
+		unique.emplace(key, id);
+		nodes.emplace(id, key);
+		return id;
+	}
+
+	int build(const bexpr<node>& e) {
+		if (e->kind == bool_expr<node>::cnst) return e->value ? 1 : 0;
+		const std::string key = repr<node>(e);
+		if (auto it = build_cache.find(key); it != build_cache.end()) return it->second;
+		std::set<std::string> supp;
+		collect_support<node>(e, supp);
+		auto top = *std::min_element(supp.begin(), supp.end(), [&](const auto& a, const auto& b) {
+			return level.at(a) < level.at(b);
+		});
+		int low = build(restrict_expr<node>(e, top, false));
+		int high = build(restrict_expr<node>(e, top, true));
+		int out = mk(top, low, high);
+		build_cache.emplace(key, out);
+		return out;
+	}
+
+	int apply_or(int a, int b, std::unordered_map<long long, int>& memo) {
+		long long key = (static_cast<long long>(a) << 32) | static_cast<unsigned int>(b);
+		if (auto it = memo.find(key); it != memo.end()) return it->second;
+		if (a == 1 || b == 1) return 1;
+		if (a == 0) return b;
+		if (b == 0) return a;
+		const auto& na = nodes.at(a);
+		const auto& nb = nodes.at(b);
+		int out = 0;
+		if (level.at(na.var) == level.at(nb.var)) {
+			out = mk(na.var, apply_or(na.low, nb.low, memo), apply_or(na.high, nb.high, memo));
+		} else if (level.at(na.var) < level.at(nb.var)) {
+			out = mk(na.var, apply_or(na.low, b, memo), apply_or(na.high, b, memo));
+		} else {
+			out = mk(nb.var, apply_or(a, nb.low, memo), apply_or(a, nb.high, memo));
+		}
+		memo.emplace(key, out);
+		return out;
+	}
+
+	int exists(int root, const std::unordered_set<std::string>& quantified) {
+		std::unordered_map<int, int> memo;
+		return exists_rec(root, quantified, memo);
+	}
+
+	int reachable_nonterminal_nodes(int root) const {
+		std::unordered_set<int> seen;
+		walk(root, seen);
+		return static_cast<int>(seen.size());
+	}
+
+	int exists_rec(int node_id, const std::unordered_set<std::string>& quantified,
+		std::unordered_map<int, int>& memo) {
+		if (auto it = memo.find(node_id); it != memo.end()) return it->second;
+		if (node_id == 0 || node_id == 1) return node_id;
+		const auto& bnode = nodes.at(node_id);
+		int low = exists_rec(bnode.low, quantified, memo);
+		int high = exists_rec(bnode.high, quantified, memo);
+		int out = 0;
+		if (quantified.contains(bnode.var)) {
+			std::unordered_map<long long, int> or_memo;
+			out = apply_or(low, high, or_memo);
+		} else out = mk(bnode.var, low, high);
+		memo.emplace(node_id, out);
+		return out;
+	}
+
+	void walk(int node_id, std::unordered_set<int>& seen) const {
+		if (node_id == 0 || node_id == 1 || seen.contains(node_id)) return;
+		seen.insert(node_id);
+		const auto& n = nodes.at(node_id);
+		walk(n.low, seen);
+		walk(n.high, seen);
+	}
+};
+
+template <NodeType node>
+tref build_tau_atom(const std::string& name, size_t type_id) {
+	using tau = tree<node>;
+	return tau::build_bf_eq_0(tau::build_variable(name, type_id));
+}
+
+template <NodeType node>
+bexpr<node> bdd_to_expr(int root, bdd_manager<node>& mgr,
+	std::unordered_map<int, bexpr<node>>& memo)
+{
+	if (auto it = memo.find(root); it != memo.end()) return it->second;
+	if (root == 0) return make_const<node>(false);
+	if (root == 1) return make_const<node>(true);
+	const auto& n = mgr.nodes.at(root);
+	bexpr<node> atom = make_var<node>(n.var);
+	bexpr<node> low = bdd_to_expr<node>(n.low, mgr, memo);
+	bexpr<node> high = bdd_to_expr<node>(n.high, mgr, memo);
+	bexpr<node> out;
+	if (n.low == 0 && n.high == 1) out = atom;
+	else if (n.low == 1 && n.high == 0) out = make_not<node>(atom);
+	else if (n.low == 0) out = make_and<node>(atom, high);
+	else if (n.high == 0) out = make_and<node>(make_not<node>(atom), low);
+	else if (n.low == 1) out = make_or<node>(make_not<node>(atom), high);
+	else if (n.high == 1) out = make_or<node>(atom, low);
+	else out = make_or<node>(make_and<node>(atom, high), make_and<node>(make_not<node>(atom), low));
+	memo.emplace(root, out);
+	return out;
+}
+
+template <NodeType node>
+std::vector<std::string> order_for_support(const compile_state<node>& st,
+	const std::unordered_set<std::string>& support)
+{
+	std::vector<std::string> out;
+	for (const auto& name : choose_order<node>(st))
+		if (support.contains(name)) out.push_back(name);
+	return out;
+}
+
+template <NodeType node>
+bexpr<node> project_with_bdd(const bexpr<node>& e, const compile_state<node>& st,
+	const std::unordered_set<std::string>& quantified,
+	int* root_nodes = nullptr,
+	int* projected_nodes = nullptr)
+{
+	auto support = support_set<node>(e);
+	auto order = order_for_support<node>(st, support);
+	if (order.empty()) return e;
+	bdd_manager<node> mgr(order);
+	int root = mgr.build(e);
+	int projected = mgr.exists(root, quantified);
+	if (root_nodes) *root_nodes += mgr.reachable_nonterminal_nodes(root);
+	if (projected_nodes) *projected_nodes += mgr.reachable_nonterminal_nodes(projected);
+	std::unordered_map<int, bexpr<node>> expr_memo;
+	return bdd_to_expr<node>(projected, mgr, expr_memo);
+}
+
+template <NodeType node>
+std::optional<bexpr<node>> project_components_with_bdd(
+	const bexpr<node>& e,
+	const compile_state<node>& st,
+	size_t* component_count = nullptr,
+	int* root_nodes = nullptr,
+	int* projected_nodes = nullptr)
+{
+	std::vector<bexpr<node>> free_factors;
+	auto groups = quantified_components<node>(e, st, free_factors);
+	if (groups.empty()) return conjoin<node>(free_factors);
+	if (groups.size() == 1 && free_factors.empty()) return {};
+	if (component_count) *component_count = groups.size();
+
+	std::vector<bexpr<node>> projected;
+	projected.reserve(free_factors.size() + groups.size());
+	projected.insert(projected.end(), free_factors.begin(), free_factors.end());
+	for (const auto& group : groups) {
+		bexpr<node> group_expr = conjoin<node>(group.factors);
+		projected.push_back(project_with_bdd<node>(
+			group_expr, st, group.quantified, root_nodes, projected_nodes));
+	}
+	return conjoin<node>(projected);
+}
+
+template <NodeType node>
+tref expr_to_tau(const bexpr<node>& e, const compile_state<node>& st)
+{
+	using tau = tree<node>;
+	switch (e->kind) {
+		case bool_expr<node>::cnst: return e->value ? tau::_T() : tau::_F();
+		case bool_expr<node>::var: return build_tau_atom<node>(e->name, st.types.at(e->name));
+		case bool_expr<node>::neg: return tau::build_wff_neg(expr_to_tau<node>(e->left, st));
+		case bool_expr<node>::land: return tau::build_wff_and(expr_to_tau<node>(e->left, st), expr_to_tau<node>(e->right, st));
+		case bool_expr<node>::lor: return tau::build_wff_or(expr_to_tau<node>(e->left, st), expr_to_tau<node>(e->right, st));
+	}
+	return tau::_F();
+}
+
+template <NodeType node>
+std::optional<tref> run(tref fm) {
+	using clock = std::chrono::steady_clock;
+	auto t0 = clock::now();
+	if (auto_enabled() && rel_auto_guard_enabled()
+		&& has_nonzero_equality_atom<node>(fm))
+	{
+		auto t_guard = clock::now();
+		if (stats_enabled()) {
+			const size_t q = leading_exists_count<node>(fm);
+			const size_t f = get_free_vars<node>(fm).size();
+			const int_t n = node_count<node>(fm);
+			auto guard_ms = std::chrono::duration<double, std::milli>(t_guard - t0).count();
+			std::cerr
+				<< "[qelim_bdd] vars=" << (q + f)
+				<< " quantified=" << q
+				<< " route=auto_rel_guard"
+				<< " components=0"
+				<< " root_nodes=0"
+				<< " projected_nodes=0"
+				<< " compile_ms=0"
+				<< " project_ms=" << guard_ms
+				<< " rebuild_ms=0"
+				<< " pure_drops=0"
+				<< " blocked_drops=0"
+				<< " blocked_clause_drops=0"
+				<< " dp_drops=0"
+				<< " dp_resolvents=0"
+				<< " dp_clause_drops=0"
+				<< " dp_subsumed=0"
+				<< " kb_steps=0"
+				<< " kb_demorgan=0"
+				<< " kb_absorption=0"
+				<< " kb_discarded=0"
+				<< " kb_guard_absorption=0"
+				<< " kb_guard_demorgan=0"
+				<< " kb_guard_double_compl=0"
+				<< " kb_guard_ran=0"
+				<< " kb_before_nodes=0"
+				<< " kb_after_nodes=0"
+				<< " guard_tree_nodes=" << n
+				<< " guard_free=" << f
+				<< "\n";
+		}
+		return {};
+	}
+	size_t tau_guard_quantified = 0;
+	size_t tau_guard_free = 0;
+	int_t tau_guard_nodes = 0;
+	if (reject_auto_tau_shape<node>(
+		fm, &tau_guard_quantified, &tau_guard_free, &tau_guard_nodes))
+	{
+		auto t_guard = clock::now();
+		if (stats_enabled()) {
+			auto guard_ms = std::chrono::duration<double, std::milli>(t_guard - t0).count();
+			std::cerr
+				<< "[qelim_bdd] vars=" << (tau_guard_quantified + tau_guard_free)
+				<< " quantified=" << tau_guard_quantified
+				<< " route=auto_guard"
+				<< " components=0"
+				<< " root_nodes=0"
+				<< " projected_nodes=0"
+				<< " compile_ms=0"
+				<< " project_ms=" << guard_ms
+				<< " rebuild_ms=0"
+				<< " pure_drops=0"
+				<< " blocked_drops=0"
+				<< " blocked_clause_drops=0"
+				<< " dp_drops=0"
+				<< " dp_resolvents=0"
+				<< " dp_clause_drops=0"
+				<< " dp_subsumed=0"
+				<< " guard_tree_nodes=" << tau_guard_nodes
+				<< " guard_free=" << tau_guard_free
+				<< "\n";
+		}
+		return {};
+	}
+	compile_state<node> st;
+	auto compiled = compile_tau_formula<node>(fm, st);
+	if (!compiled) {
+		auto t_reject = clock::now();
+		if (stats_enabled()) {
+			auto compile_ms = std::chrono::duration<double, std::milli>(t_reject - t0).count();
+			std::cerr
+				<< "[qelim_bdd] vars=" << st.appearance_order.size()
+				<< " quantified=" << st.quantified.size()
+				<< " route=compile_reject"
+				<< " components=0"
+				<< " root_nodes=0"
+				<< " projected_nodes=0"
+				<< " compile_ms=" << compile_ms
+				<< " project_ms=0"
+				<< " rebuild_ms=0"
+				<< " pure_drops=0"
+				<< " blocked_drops=0"
+				<< " blocked_clause_drops=0"
+				<< " dp_drops=0"
+				<< " dp_resolvents=0"
+				<< " dp_clause_drops=0"
+				<< " dp_subsumed=0"
+				<< " kb_steps=0"
+				<< " kb_demorgan=0"
+				<< " kb_absorption=0"
+				<< " kb_discarded=0"
+				<< " kb_guard_absorption=0"
+				<< " kb_guard_demorgan=0"
+				<< " kb_guard_double_compl=0"
+				<< " kb_guard_ran=0"
+				<< " kb_before_nodes=0"
+				<< " kb_after_nodes=0"
+				<< "\n";
+		}
+		return {};
+	}
+	auto t1 = clock::now();
+
+	size_t pure_drops = 0;
+	size_t blocked_drops = 0;
+	size_t blocked_clause_drops = 0;
+	size_t dp_drops = 0;
+	size_t dp_resolvents = 0;
+	size_t dp_clause_drops = 0;
+	size_t dp_subsumed = 0;
+	kb_rewrite_stats<node> kb_stats;
+	bexpr<node> working = *compiled;
+	auto preflight = compute_preflight_metrics<node>(working, st.quantified);
+	if (reject_auto_high_duplication_shape<node>(preflight)) {
+		auto t_guard = clock::now();
+		if (stats_enabled()) {
+			auto compile_ms = std::chrono::duration<double, std::milli>(t1 - t0).count();
+			auto guard_ms = std::chrono::duration<double, std::milli>(t_guard - t1).count();
+			std::cerr
+				<< "[qelim_bdd] vars=" << st.appearance_order.size()
+				<< " quantified=" << st.quantified.size()
+				<< " route=auto_dup_guard"
+				<< " components=0"
+				<< " root_nodes=0"
+				<< " projected_nodes=0"
+				<< " compile_ms=" << compile_ms
+				<< " project_ms=" << guard_ms
+				<< " rebuild_ms=0"
+				<< " pure_drops=0"
+				<< " blocked_drops=0"
+				<< " blocked_clause_drops=0"
+				<< " dp_drops=0"
+				<< " dp_resolvents=0"
+				<< " dp_clause_drops=0"
+				<< " dp_subsumed=0"
+				<< " preflight_tree_nodes=" << preflight.tree_nodes
+				<< " preflight_unique_nodes=" << preflight.unique_nodes
+				<< " preflight_support=" << preflight.support
+				<< " preflight_free=" << preflight.free
+				<< " preflight_max_occurrence=" << preflight.max_occurrence
+				<< "\n";
+		}
+		return {};
+	}
+	if (ac_canon_enabled())
+		working = normalize_ac<node>(working);
+	if (kb_rewrite_enabled()) {
+		scan_kb_opportunities<node>(working, kb_stats);
+		if (!kb_rewrite_guarded() || kb_stats.guard_absorption > 0)
+			working = normalize_kb<node>(working, &kb_stats);
+		else {
+			kb_stats.before_nodes = expr_nodes<node>(working);
+			kb_stats.after_nodes = kb_stats.before_nodes;
+		}
+	}
+	if (pure_enabled())
+		working = drop_pure_quantified<node>(working, st, &pure_drops);
+	if (blocked_enabled())
+		working = drop_blocked_quantified_cnf<node>(
+			working, st, &blocked_drops, &blocked_clause_drops);
+	if (auto cap = dp_cap())
+		working = distribute_quantified_cnf_under_cap<node>(
+			working, st, *cap, &dp_drops, &dp_resolvents,
+			&dp_clause_drops, &dp_subsumed);
+
+	std::vector<std::string> order = choose_order<node>(st);
+	if (order.empty()) return fm;
+
+	size_t component_count = 0;
+	int root_nodes = 0;
+	int projected_nodes = 0;
+	bexpr<node> simplified;
+	std::string route = "monolithic";
+
+	if (!has_quantified_support<node>(working, st)) {
+		simplified = working;
+		if (dp_drops > 0) route = (pure_drops > 0 || blocked_drops > 0) ? "preprocess" : "dp";
+		else if (blocked_drops > 0) route = pure_drops > 0 ? "preprocess" : "blocked";
+		else route = pure_drops > 0 ? "pure" : "residual";
+	} else if (components_enabled()) {
+		if (auto component_result = project_components_with_bdd<node>(
+			working, st, &component_count, &root_nodes, &projected_nodes))
+		{
+			simplified = *component_result;
+			route = "components";
+		}
+	}
+
+	if (route == "monolithic") {
+		bdd_manager<node> mgr(order);
+		int root = mgr.build(working);
+		root_nodes = mgr.reachable_nonterminal_nodes(root);
+		int projected = mgr.exists(root, st.quantified);
+		projected_nodes = mgr.reachable_nonterminal_nodes(projected);
+		std::unordered_map<int, bexpr<node>> expr_memo;
+		simplified = bdd_to_expr<node>(projected, mgr, expr_memo);
+	}
+	auto t2 = clock::now();
+	tref rebuilt = expr_to_tau<node>(simplified, st);
+	auto t3 = clock::now();
+	if (stats_enabled()) {
+		auto compile_ms = std::chrono::duration<double, std::milli>(t1 - t0).count();
+		auto build_ms = std::chrono::duration<double, std::milli>(t2 - t1).count();
+		auto rebuild_ms = std::chrono::duration<double, std::milli>(t3 - t2).count();
+		std::cerr
+			<< "[qelim_bdd] vars=" << st.appearance_order.size()
+			<< " quantified=" << st.quantified.size()
+			<< " route=" << route
+			<< " components=" << component_count
+			<< " root_nodes=" << root_nodes
+			<< " projected_nodes=" << projected_nodes
+			<< " compile_ms=" << compile_ms
+			<< " project_ms=" << build_ms
+			<< " rebuild_ms=" << rebuild_ms
+			<< " pure_drops=" << pure_drops
+			<< " blocked_drops=" << blocked_drops
+			<< " blocked_clause_drops=" << blocked_clause_drops
+			<< " dp_drops=" << dp_drops
+			<< " dp_resolvents=" << dp_resolvents
+			<< " dp_clause_drops=" << dp_clause_drops
+			<< " dp_subsumed=" << dp_subsumed
+			<< " kb_steps=" << kb_stats.steps
+			<< " kb_demorgan=" << kb_stats.demorgan
+			<< " kb_absorption=" << kb_stats.absorption
+			<< " kb_discarded=" << kb_stats.discarded
+			<< " kb_guard_absorption=" << kb_stats.guard_absorption
+			<< " kb_guard_demorgan=" << kb_stats.guard_demorgan
+			<< " kb_guard_double_compl=" << kb_stats.guard_double_compl
+			<< " kb_guard_ran=" << kb_stats.guard_ran
+			<< " kb_before_nodes=" << kb_stats.before_nodes
+			<< " kb_after_nodes=" << kb_stats.after_nodes
+			<< "\n";
+	}
+	return rebuilt;
+}
