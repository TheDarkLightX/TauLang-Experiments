+
+	static size_t find_parent(std::vector<size_t>& parent, size_t x) {
+		while (parent[x] != x) {
+			parent[x] = parent[parent[x]];
+			x = parent[x];
+		}
+		return x;
+	}
+
+	static bool disjunction_connects_alias_class(tref disj, const trefs& alias_class) {
+		if (alias_class.size() <= 1) return false;
+		trefs disjs = get_dnf_wff_clauses<node>(disj);
+		std::vector<size_t> parent(alias_class.size());
+		for (size_t i = 0; i < parent.size(); ++i) parent[i] = i;
+		for (tref d : disjs) {
+			tref l, r;
+			if (!atom_sides(d, tau::bf_neq, l, r)) return false;
+			auto li = same_index(alias_class, l);
+			auto ri = same_index(alias_class, r);
+			if (!li || !ri) return false;
+			size_t lp = find_parent(parent, *li);
+			size_t rp = find_parent(parent, *ri);
+			if (lp != rp) parent[rp] = lp;
+		}
+		size_t root = find_parent(parent, 0);
+		for (size_t i = 1; i < parent.size(); ++i)
+			if (find_parent(parent, i) != root) return false;
+		return true;
+	}
+
+	static size_t intern_alias_term(trefs& terms, tref term) {
+		if (auto idx = same_index(terms, term)) return *idx;
+		terms.push_back(term);
+		return terms.size() - 1;
+	}
+
+	static bool disjunction_complements_aliases_by_components(
+		tref disj, const trefs& aliases)
+	{
+		trefs terms;
+		std::vector<std::pair<size_t, size_t>> alias_edges;
+		for (tref alias : aliases) {
+			tref l, r;
+			if (!atom_sides(alias, tau::bf_eq, l, r)) return false;
+			size_t li = intern_alias_term(terms, l);
+			size_t ri = intern_alias_term(terms, r);
+			alias_edges.emplace_back(li, ri);
+		}
+		if (alias_edges.empty()) return false;
+
+		std::vector<size_t> parent(terms.size());
+		for (size_t i = 0; i < parent.size(); ++i) parent[i] = i;
+		for (tref d : get_dnf_wff_clauses<node>(disj)) {
+			tref l, r;
+			if (!atom_sides(d, tau::bf_neq, l, r)) return false;
+			auto li = same_index(terms, l);
+			auto ri = same_index(terms, r);
+			if (!li || !ri) continue;
+			size_t lp = find_parent(parent, *li);
+			size_t rp = find_parent(parent, *ri);
+			if (lp != rp) parent[rp] = lp;
+		}
+		for (auto [li, ri] : alias_edges)
+			if (find_parent(parent, li) != find_parent(parent, ri))
+				return false;
+		return true;
+	}
+
+	static size_t find_or_add_term(std::vector<tref>& terms, tref x) {
+		for (size_t i = 0; i < terms.size(); ++i)
+			if (same_tree(terms[i], x)) return i;
+		terms.push_back(x);
+		return terms.size() - 1;
+	}
+
+	static bool eqs_connect_terms(const trefs& eqs, tref a, tref b) {
+		if (same_tree(a, b)) return true;
+		std::vector<tref> terms;
+		find_or_add_term(terms, a);
+		find_or_add_term(terms, b);
+		for (tref eq : eqs) {
+			tref l, r;
+			if (!atom_sides(eq, tau::bf_eq, l, r)) continue;
+			find_or_add_term(terms, l);
+			find_or_add_term(terms, r);
+		}
+		std::vector<size_t> parent(terms.size());
+		for (size_t i = 0; i < parent.size(); ++i) parent[i] = i;
+		for (tref eq : eqs) {
+			tref l, r;
+			if (!atom_sides(eq, tau::bf_eq, l, r)) continue;
+			size_t li = find_or_add_term(terms, l);
+			size_t ri = find_or_add_term(terms, r);
+			size_t lp = find_parent(parent, li);
+			size_t rp = find_parent(parent, ri);
+			if (lp != rp) parent[rp] = lp;
+		}
+		size_t ai = find_or_add_term(terms, a);
+		size_t bi = find_or_add_term(terms, b);
+		return find_parent(parent, ai) == find_parent(parent, bi);
+	}
+
+	static bool disjunction_neq_edges_connect_terms(tref disj, tref a, tref b) {
+		trefs evidence;
+		for (tref d : get_dnf_wff_clauses<node>(disj)) {
+			tref l, r;
+			if (!atom_sides(d, tau::bf_neq, l, r)) return false;
+			evidence.push_back(tau::build_bf_eq(l, r));
+		}
+		return eqs_connect_terms(evidence, a, b);
+	}
+
+	static bool parse_zero_meet_pos_neg(tref atom, tref& pos, tref& neg) {
+		auto zero = zero_eq_term(atom);
+		if (!zero) return false;
+		if (!tau::get(*zero).is(tau::bf)) return false;
+		if (!tau::get(*zero).child_is(tau::bf_and)) return false;
+		tref l = tau::get(*zero)[0].first();
+		tref r = tau::get(*zero)[0].second();
+		if (tau::get(l).child_is(tau::bf_neg)) {
+			pos = r;
+			neg = tau::trim2(l);
+			return true;
+		}
+		if (tau::get(r).child_is(tau::bf_neg)) {
+			pos = l;
+			neg = tau::trim2(r);
+			return true;
+		}
+		return false;
+	}
+
+	static std::optional<tref> reduce_zero_neq_under_aliases(
+		tref candidate, tref residual, const trefs& aliases)
+	{
+		auto candidate_term = zero_neq_term(candidate);
+		auto residual_term = zero_neq_term(residual);
+		if (!candidate_term || !residual_term) return {};
+
+		tref normalized_candidate = reduce<node>(to_dnf<node, false>(
+			normalize_ba<node>(*candidate_term)));
+		if (term_rewrites_to_under_aliases(
+				*residual_term, normalized_candidate, aliases))
+			return syntactic_formula_simplification<node>(
+				tau::build_bf_neq_0(normalized_candidate));
+		if (term_rewrites_to_under_aliases(
+				normalized_candidate, *residual_term, aliases))
+			return syntactic_formula_simplification<node>(
+				tau::build_bf_neq_0(normalized_candidate));
+
+		trefs alias_class = alias_class_for_residual(*residual_term, aliases);
+
+		subtree_map<node, tref> changes;
+		for (tref item : alias_class) {
+			if (!same_tree(item, *residual_term))
+				changes[item] = *residual_term;
+		}
+		if (changes.empty()) return {};
+
+		tref substituted = rewriter::replace<node>(*candidate_term, changes);
+		tref reduced = reduce<node>(to_dnf<node, false>(
+			normalize_ba<node>(substituted)));
+		if (!same_tree(reduced, *residual_term)) return {};
+		return syntactic_formula_simplification<node>(
+			tau::build_bf_neq_0(normalized_candidate));
+	}
+
+	static tref normalize_ba_term(tref term) {
+		return reduce<node>(to_dnf<node, false>(normalize_ba<node>(term)));
+	}
+
+	static bool add_alias_class_rewrites(
+		subtree_map<node, tref>& changes, tref rep, const trefs& aliases)
+	{
+		for (tref item : alias_class_for_residual(rep, aliases)) {
+			if (same_tree(item, rep)) continue;
+			auto existing = changes.find(item);
+			if (existing != changes.end() && !same_tree(existing->second, rep))
+				return false;
+			changes[item] = rep;
+		}
+		return true;
+	}
+
+	static bool add_rewrite(
+		subtree_map<node, tref>& changes, tref from, tref to)
+	{
+		if (same_tree(from, to)) return true;
+		auto existing = changes.find(from);
+		if (existing != changes.end())
+			return same_tree(existing->second, to);
+		changes[from] = to;
+		return true;
+	}
+
+	static bool term_rewrites_to_under_aliases(
+		tref from, tref to, const trefs& aliases)
+	{
+		if (same_tree(normalize_ba_term(from), normalize_ba_term(to)))
+			return true;
+		std::vector<std::pair<tref, tref>> pairs;
+		for (tref eq : aliases) {
+			tref l, r;
+			if (!atom_sides(eq, tau::bf_eq, l, r)) continue;
+			pairs.push_back({l, r});
+		}
+		if (pairs.empty() || pairs.size() > 6) return false;
+		size_t orientations = size_t{1} << pairs.size();
+		tref target = normalize_ba_term(to);
+		for (size_t mask = 0; mask < orientations; ++mask) {
+			subtree_map<node, tref> changes;
+			bool ok = true;
+			for (size_t i = 0; i < pairs.size(); ++i) {
+				tref l = pairs[i].first;
+				tref r = pairs[i].second;
+				if ((mask >> i) & 1)
+					ok = add_rewrite(changes, l, r);
+				else
+					ok = add_rewrite(changes, r, l);
+				if (!ok) break;
+			}
+			if (!ok || changes.empty()) continue;
+			tref substituted = normalize_ba_term(
+				rewriter::replace<node>(from, changes));
+			if (same_tree(substituted, target)) return true;
+		}
+		return false;
+	}
+
+	static bool term_pair_rewrites_to_under_aliases(
+		tref from_l, tref from_r, tref to_l, tref to_r, const trefs& aliases)
+	{
+		return (
+			term_rewrites_to_under_aliases(from_l, to_l, aliases)
+			&& term_rewrites_to_under_aliases(from_r, to_r, aliases))
+			|| (
+			term_rewrites_to_under_aliases(from_l, to_r, aliases)
+			&& term_rewrites_to_under_aliases(from_r, to_l, aliases));
+	}
+
+	static bool atom_implied_by_aliases(tref atom, const trefs& aliases) {
+		tref l, r;
+		if (atom_sides(atom, tau::bf_eq, l, r))
+			return eqs_connect_terms(aliases, l, r)
+				|| term_rewrites_to_under_aliases(l, r, aliases)
+				|| term_rewrites_to_under_aliases(r, l, aliases);
+		tref pos, neg;
+		if (parse_zero_meet_pos_neg(atom, pos, neg))
+			return eqs_connect_terms(aliases, pos, neg)
+				|| term_rewrites_to_under_aliases(pos, neg, aliases)
+				|| term_rewrites_to_under_aliases(neg, pos, aliases);
+		return false;
+	}
+
+	static bool atom_redundant_under_aliases(tref atom, const trefs& aliases) {
+		trefs with_atom = aliases;
+		with_atom.push_back(atom);
+		tref simplified = simplify_using_equality<node>::on(
+			tau::build_wff_and(with_atom));
+		trefs reduced = get_cnf_wff_clauses<node>(simplified);
+		trefs expected = aliases;
+		std::ranges::stable_sort(reduced, tau::subtree_less);
+		std::ranges::stable_sort(expected, tau::subtree_less);
+		return same_multiset(reduced, expected);
+	}
+
+	static bool residual_and_negated_disj_imply_aliases(
+		tref residual, tref disj, const trefs& aliases)
+	{
+		trefs evidence;
+		for (tref d : get_dnf_wff_clauses<node>(disj)) {
+			tref l, r;
+			if (!atom_sides(d, tau::bf_neq, l, r)) return false;
+			evidence.push_back(tau::build_bf_eq(l, r));
+		}
+		tref l, r;
+		if (atom_sides(residual, tau::bf_eq, l, r))
+			evidence.push_back(tau::build_bf_eq(l, r));
+		for (tref alias : aliases)
+			if (!atom_implied_by_aliases(alias, evidence)) return false;
+		return true;
+	}
+
+	static std::optional<tref> recombine_alias_implies_residual_partition_one_way(
+		const trefs& alias_branch, const trefs& complement_branch)
+	{
+		if (alias_branch.empty()) return {};
+		for (tref alias : alias_branch) {
+			tref l, r;
+			if (!atom_sides(alias, tau::bf_eq, l, r)) return {};
+		}
+		for (size_t residual_i = 0; residual_i < complement_branch.size(); ++residual_i) {
+			tref residual = complement_branch[residual_i];
+			if (!atom_implied_by_aliases(residual, alias_branch))
+				continue;
+			trefs rest = without_index(complement_branch, residual_i);
+			if (rest.size() != 1) continue;
+			if (disjunction_negates_all(rest[0], alias_branch)
+				|| residual_and_negated_disj_imply_aliases(
+					residual, rest[0], alias_branch))
+				return syntactic_formula_simplification<node>(residual);
+		}
+		return {};
+	}
+
+	static std::optional<tref> recombine_alias_implies_residual_partition(
+		const trefs& left, const trefs& right)
+	{
+		if (auto res = recombine_alias_implies_residual_partition_one_way(left, right))
+			return *res;
+		return recombine_alias_implies_residual_partition_one_way(right, left);
+	}
+
+	static std::optional<tref> reduce_eqneq_under_aliases(
+		tref candidate, tref residual, const trefs& aliases)
+	{
+		size_t candidate_type, residual_type;
+		tref cl, cr, rl, rr;
+		if (!eq_neq_atom(candidate, candidate_type, cl, cr)) return {};
+		if (!eq_neq_atom(residual, residual_type, rl, rr)) return {};
+		if (candidate_type != residual_type) return {};
+
+		if (term_pair_rewrites_to_under_aliases(rl, rr, cl, cr, aliases))
+			return syntactic_formula_simplification<node>(candidate);
+		if (term_pair_rewrites_to_under_aliases(cl, cr, rl, rr, aliases))
+			return syntactic_formula_simplification<node>(candidate);
+
+		subtree_map<node, tref> changes;
+		if (!add_alias_class_rewrites(changes, cl, aliases)) return {};
+		if (!add_alias_class_rewrites(changes, cr, aliases)) return {};
+		if (changes.empty()) return {};
+
+		tref sl = normalize_ba_term(rewriter::replace<node>(rl, changes));
+		tref sr = normalize_ba_term(rewriter::replace<node>(rr, changes));
+		tref ncl = normalize_ba_term(cl);
+		tref ncr = normalize_ba_term(cr);
+		if (!same_unordered_pair(sl, sr, ncl, ncr)) return {};
+		return syntactic_formula_simplification<node>(candidate);
+	}
+
+	static std::optional<tref> recombine_alias_eqneq_partition_one_way(
+		const trefs& alias_branch, const trefs& complement_branch)
+	{
+		for (size_t residual_i = 0; residual_i < alias_branch.size(); ++residual_i) {
+			tref l, r;
+			size_t atom_type;
+			if (!eq_neq_atom(alias_branch[residual_i], atom_type, l, r))
+				continue;
+
+			trefs aliases;
+			bool alias_ok = true;
+			for (size_t i = 0; i < alias_branch.size(); ++i) {
+				if (i == residual_i) continue;
+				if (atom_sides(alias_branch[i], tau::bf_eq, l, r))
+					aliases.push_back(alias_branch[i]);
+				else {
+					alias_ok = false;
+					break;
+				}
+			}
+			if (!alias_ok || aliases.empty()) continue;
+
+			for (size_t candidate_i = 0; candidate_i < complement_branch.size(); ++candidate_i) {
+				if (!eq_neq_atom(complement_branch[candidate_i], atom_type, l, r))
+					continue;
+				trefs complement_rest = without_index(complement_branch, candidate_i);
+				if (complement_rest.size() != 1) continue;
+				if (!disjunction_negates_all(complement_rest[0], aliases)
+					&& !disjunction_complements_aliases_by_components(
+						complement_rest[0], aliases))
+					continue;
+				if (auto reduced = reduce_eqneq_under_aliases(
+						complement_branch[candidate_i],
+						alias_branch[residual_i],
+						aliases))
+					return *reduced;
+			}
+		}
+		return {};
+	}
+
+	static std::optional<tref> recombine_alias_eqneq_partition(
+		const trefs& left, const trefs& right)
+	{
+		if (auto res = recombine_alias_eqneq_partition_one_way(left, right))
+			return *res;
+		return recombine_alias_eqneq_partition_one_way(right, left);
+	}
+
+	static std::optional<tref> recombine_alias_true_residual_partition_one_way(
+		const trefs& alias_branch, const trefs& complement_branch)
+	{
+		if (alias_branch.empty()) return {};
+		for (tref alias : alias_branch) {
+			tref l, r;
+			if (!atom_sides(alias, tau::bf_eq, l, r)) return {};
+		}
+		for (size_t candidate_i = 0; candidate_i < complement_branch.size(); ++candidate_i) {
+			tref candidate = complement_branch[candidate_i];
+			tref l, r;
+			size_t atom_type;
+			if (!eq_neq_atom(candidate, atom_type, l, r)) continue;
+			if (!atom_implied_by_aliases(candidate, alias_branch)
+				&& !atom_redundant_under_aliases(candidate, alias_branch))
+				continue;
+			trefs complement_rest = without_index(complement_branch, candidate_i);
+			if (complement_rest.size() != 1) continue;
+			if (!disjunction_negates_all(complement_rest[0], alias_branch)
+				&& !disjunction_complements_aliases_by_components(
+					complement_rest[0], alias_branch))
+				continue;
+			return syntactic_formula_simplification<node>(candidate);
+		}
+		return {};
+	}
+
+	static std::optional<tref> recombine_alias_true_residual_partition(
+		const trefs& left, const trefs& right)
+	{
+		if (auto res = recombine_alias_true_residual_partition_one_way(left, right))
+			return *res;
+		return recombine_alias_true_residual_partition_one_way(right, left);
+	}
+
+	static std::optional<tref> recombine_alias_residual_partition_one_way(
+		const trefs& alias_branch, const trefs& complement_branch)
+	{
+		trefs aliases;
+		tref residual = nullptr;
+		for (tref item : alias_branch) {
+			tref l, r;
+			if (atom_sides(item, tau::bf_eq, l, r)) aliases.push_back(item);
+			else if (zero_neq_term(item)) {
+				if (residual) return {};
+				residual = item;
+			} else return {};
+		}
+		if (aliases.empty() || !residual) return {};
+		trefs alias_class = alias_class_for_residual(
+			*zero_neq_term(residual), aliases);
+
+		tref complement = nullptr;
+		tref candidate = nullptr;
+		for (tref item : complement_branch) {
+			if (disjunction_negates_all(item, aliases)
+				|| disjunction_connects_alias_class(item, alias_class)) {
+				if (complement) return {};
+				complement = item;
+			} else if (zero_neq_term(item)) {
+				if (candidate) return {};
+				candidate = item;
+			} else return {};
+		}
+		if (!complement || !candidate) return {};
+		return reduce_zero_neq_under_aliases(candidate, residual, aliases);
+	}
+
+	static std::optional<tref> recombine_alias_residual_partition(
+		const trefs& left, const trefs& right)
+	{
+		if (auto res = recombine_alias_residual_partition_one_way(left, right))
+			return *res;
+		return recombine_alias_residual_partition_one_way(right, left);
+	}
+
+	static tref build_wff_and_or_true(const trefs& xs) {
+		if (xs.empty()) return _T<node>();
+		return tau::build_wff_and(xs);
+	}
+
+	static tref recombine_wff_split_node(tref n) {
+		if (!tau::get(n).is(tau::wff)) return n;
+		const tau& t = tau::get(n)[0];
+		if (t.is(tau::wff_and)) {
+			trefs clauses = get_cnf_wff_clauses<node>(n);
+			for (size_t i = 0; i < clauses.size(); ++i) {
+				tref l, r;
+				if (!atom_sides(clauses[i], tau::bf_neq, l, r)) continue;
+				for (size_t j = 0; j < clauses.size(); ++j) {
+					if (i == j) continue;
+					if (!disjunction_neq_edges_connect_terms(clauses[j], l, r))
+						continue;
+					trefs rest = without_index(clauses, j);
+					return build_wff_and_or_true(rest);
+				}
+			}
+			return n;
+		}
+		if (!t.is(tau::wff_or)) return n;
+
+		trefs left = get_cnf_wff_clauses<node>(t.first());
+		trefs right = get_cnf_wff_clauses<node>(t.second());
+		for (size_t i = 0; i < left.size(); ++i) {
+			for (size_t j = 0; j < right.size(); ++j) {
+				if (!neg_pair(left[i], right[j])) continue;
+				trefs left_rest = without_index(left, i);
+				trefs right_rest = without_index(right, j);
+				if (same_multiset(left_rest, right_rest))
+					return build_wff_and_or_true(left_rest);
+			}
+		}
+		if (auto partition = recombine_common_residual_partition(left, right))
+			return *partition;
+		if (auto implied_residual =
+				recombine_alias_implies_residual_partition(left, right))
+			return *implied_residual;
+		if (auto eqneq_part = recombine_alias_eqneq_partition(left, right))
+			return *eqneq_part;
+		if (auto alias_true = recombine_alias_true_residual_partition(left, right))
+			return *alias_true;
+		if (auto alias_part = recombine_alias_residual_partition(left, right))
+			return *alias_part;
+		if (auto zero_part = recombine_zero_partition(left, right))
+			return *zero_part;
+		if (auto implied = recombine_equality_implied_atom(left, right))
+			return *implied;
+		return n;
+	}
+
+	static tref recombine_wff_splits(tref root) {
+		if (!feature_equality_split_recombine()) return root;
+		return pre_order<node>(root).template
+			apply_unique<synt_path_simp_m>(
+				recombine_wff_split_node, visit_wff<node>);
+	}
